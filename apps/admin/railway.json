{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm turbo build --filter=@lylrv/admin",
    "watchPatterns": ["apps/admin/**", "packages/**", "tooling/**"]
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "pnpm dotenv -e .env -- node apps/admin/.output/server/index.mjs",
    "limitOverride": {
      "containers": {
        "cpu": 3,
        "memoryBytes": 3000000000
      }
    },
    "sleepApplication": true,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 3
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
