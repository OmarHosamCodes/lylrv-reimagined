{
  "name": "lylrv-reimagined",
  "private": true,
  "engines": {
    "pnpm": "^10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "build:widgets": "pnpm -F @lylrv/widgets build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @lylrv/auth generate",
    "db:push": "turbo -F @lylrv/db push",
    "db:studio": "turbo -F @lylrv/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @lylrv/saas...",
    "dev:widgets": "pnpm -F @lylrv/widgets dev",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "check:lint": "biome lint --write --unsafe .",
    "format": "biome format .",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@turbo/gen": "^2.8.10",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.8.10",
    "typescript": "catalog:"
  }
}
