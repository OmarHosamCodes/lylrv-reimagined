{
  "name": "create-t3-turbo",
  "private": true,
  "engines": {
    "pnpm": "^10.30.1"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo run build",
    "build:widgets": "pnpm -F @lylrv/widgets build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @lylrv/auth generate",
    "db:push": "turbo -F @lylrv/db push",
    "db:studio": "turbo -F @lylrv/db studio",
    "dev": "turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @lylrv/saas...",
    "dev:widgets": "pnpm -F @lylrv/widgets dev",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "check:lint": "biome lint --write --unsafe .",
    "format": "biome format .",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@turbo/gen": "^2.8.10",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.8.10",
    "typescript": "catalog:"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "@better-auth/cli": "1.4.0-beta.9",
      "@tailwindcss/postcss": "^4.1.16",
      "@tailwindcss/vite": "^4.1.16",
      "@tanstack/react-form": "^1.23.8",
      "@tanstack/react-query": "^5.90.8",
      "@trpc/client": "^11.7.1",
      "@trpc/server": "^11.7.1",
      "@trpc/tanstack-react-query": "^11.7.1",
      "@types/node": "22.18.12",
      "@vitejs/plugin-react": "5.1.0",
      "better-auth": "1.4.0-beta.9",
      "tailwindcss": "^4.1.16",
      "typescript": "^5.9.3",
      "vite": "7.1.12",
      "zod": "^4.1.12",
      "zustand": "^5.0.0"
    },
    "catalogs": {
      "react19": {
        "@types/react": "~19.1.0",
        "@types/react-dom": "~19.1.0",
        "react": "19.1.4",
        "react-dom": "19.1.4"
      }
    }
  },
  "overrides": {
    "@types/minimatch": "5.1.2",
    "lightningcss": "1.30.1",
    "vite": "7.1.12"
  }
}
